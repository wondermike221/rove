{
  "name": "rove",
  "version": "0.1.0",
  "type": "module",
  "description": "Dual-mode command palette and directory navigation UI component",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "demo": "vite --config vite.demo.config.ts",
    "build": "tsc --noEmit && vite build",
    "build:userscript": "vite build --config vite.userscript.config.ts",
    "build:all": "npm run build && npm run build:userscript",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "solid-js": "^1.8.0",
    "solid-transition-group": "^0.3.0"
  },
  "devDependencies": {
    "@leeoniya/ufuzzy": "^1.0.19",
    "solid-js": "^1.9.7",
    "solid-transition-group": "^0.3.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-solid": "^2.11.7"
  }
}
